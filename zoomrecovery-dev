#!/bin/bash
set -euo pipefail

# ── User / Home Detection ───────────────────────────────────────────────────
TARGET_USER="${SUDO_USER:-$USER}"
TARGET_HOME=$(dscl . -read "/Users/$TARGET_USER" NFSHomeDirectory 2>/dev/null | awk '{print $NF}')
if [[ -z "$TARGET_HOME" ]]; then
  TARGET_HOME="$(cd ~"$TARGET_USER" 2>/dev/null && pwd)" || TARGET_HOME=""
fi
export TARGET_USER TARGET_HOME

CONSOLE_USER="$(stat -f %Su /dev/console)"
if [ -z "${TARGET_HOME:-}" ] || [ ! -d "${TARGET_HOME}" ]; then
  TARGET_USER="${CONSOLE_USER}"
  TARGET_HOME=$(dscl . -read "/Users/$CONSOLE_USER" NFSHomeDirectory 2>/dev/null | awk '{print $NF}')
  if [[ -z "$TARGET_HOME" ]]; then
    TARGET_HOME="$(cd ~"$CONSOLE_USER" 2>/dev/null && pwd)" || TARGET_HOME=""
  fi
fi

VERSION="VERSION_PLACEHOLDER"
if [[ "${1:-}" == "--version" || "${1:-}" == "-v" ]]; then
  echo "zoomrecovery-dev $VERSION"
  exit 0
fi

# ── Root Escalation ─────────────────────────────────────────────────────────
if [[ $EUID -ne 0 ]]; then
  if sudo -E -- "$0" "$@"; then
    exit 0
  fi
  echo "[!] sudo failed — MAC spoofing and DNS flush require root."
  echo "[!] Continuing with partial functionality..."
  PARTIAL_MODE=true
else
  PARTIAL_MODE=false
fi

# ── Architecture & OS Detection ─────────────────────────────────────────────
ARCH="$(uname -m)"
OS_MAJOR="$(sw_vers -productVersion | cut -d. -f1)"
APPLE_SILICON_MODERN=false
if [[ "$ARCH" == "arm64" && "$OS_MAJOR" -ge 14 ]]; then
  APPLE_SILICON_MODERN=true
fi

# ── Stop Zoom ───────────────────────────────────────────────────────────────
echo "[*] Stopping Zoom..."
if pgrep -x "zoom.us" >/dev/null 2>&1; then
  killall "zoom.us" 2>/dev/null || true
  for i in {1..10}; do
    pgrep -x "zoom.us" >/dev/null 2>&1 || break
    sleep 0.5
  done
  if pgrep -x "zoom.us" >/dev/null 2>&1; then
    killall -9 "zoom.us" 2>/dev/null || true
    sleep 1
  fi
  echo "[+] Zoom stopped"
else
  echo "[*] Zoom not running"
fi

# ── Stop Zoom Updater Processes ─────────────────────────────────────────────
echo "[*] Stopping Zoom updater processes..."
for proc in zAutoUpdate zPTUpdaterUI ZoomUpdater; do
  pkill -x "$proc" 2>/dev/null || true
done

if [[ "$PARTIAL_MODE" = false ]]; then
  UID_VAL="$(id -u "$TARGET_USER")"
  for domain in "gui/${UID_VAL}" "user/${UID_VAL}"; do
    for label in us.zoom.zAutoUpdate us.zoom.ZoomUpdater us.zoom.zPTUpdaterUI; do
      launchctl bootout "$domain" "/Library/LaunchAgents/$label.plist" 2>/dev/null || true
      launchctl bootout "$domain" "${TARGET_HOME}/Library/LaunchAgents/$label.plist" 2>/dev/null || true
    done
  done
fi

# ── Detect Network Interface ───────────────────────────────────────────────
WIFI_DEVICE=""
WIFI_SERVICE=""
ACTIVE_DEVICE=""
ACTIVE_SERVICE=""
INTERFACE_KIND=""

detect_network() {
  local default_iface
  default_iface="$(route -n get default 2>/dev/null | awk '/interface:/{print $2}')" || true

  if [[ -z "$default_iface" ]]; then
    echo "[!] No default route — are you connected to a network?"
    return 1
  fi

  # Reject VPN interfaces
  case "$default_iface" in
    utun*|ipsec*|ppp*|tun*|tap*)
      echo "[!] VPN detected on $default_iface — disconnect your VPN first."
      return 1
      ;;
  esac

  ACTIVE_DEVICE="$default_iface"

  # Map device to hardware port and network service
  local current_port="" current_device=""
  while IFS= read -r line; do
    if [[ "$line" == "Hardware Port: "* ]]; then
      current_port="${line#Hardware Port: }"
    elif [[ "$line" == "Device: "* ]]; then
      current_device="${line#Device: }"
      if [[ "$current_device" == "$default_iface" ]]; then
        ACTIVE_SERVICE="$(networksetup -listnetworkserviceorder 2>/dev/null \
          | grep -B1 "Device: $current_device" \
          | head -1 \
          | sed 's/^([0-9]*) //')" || true
        if [[ "$current_port" == *"Wi-Fi"* || "$current_port" == *"wifi"* ]]; then
          INTERFACE_KIND="wifi"
          WIFI_DEVICE="$current_device"
          WIFI_SERVICE="$ACTIVE_SERVICE"
        elif [[ "$current_port" == *"Ethernet"* ]]; then
          INTERFACE_KIND="ethernet"
        fi
        break
      fi
    fi
  done < <(networksetup -listallhardwareports 2>/dev/null)

  if [[ -z "$INTERFACE_KIND" ]]; then
    echo "[!] Active interface $default_iface is not Wi-Fi or Ethernet — unsupported"
    return 1
  fi

  echo "[*] Active interface: $ACTIVE_DEVICE ($INTERFACE_KIND)"
  return 0
}

# ── MAC Address Spoofing ────────────────────────────────────────────────────
random_mac() {
  local bytes
  bytes="$(openssl rand -hex 6)"
  # Set locally-administered + unicast bits on first byte
  local first_byte
  first_byte=$(printf "%02x" $(( (0x${bytes:0:2} | 0x02) & 0xFE )))
  echo "${first_byte}:${bytes:2:2}:${bytes:4:2}:${bytes:6:2}:${bytes:8:2}:${bytes:10:2}"
}

spoof_mac() {
  if [[ "$PARTIAL_MODE" = true ]]; then
    echo "[!] Skipping MAC spoofing (requires root)"
    return
  fi

  if ! detect_network; then
    echo "[!] Skipping MAC spoofing — network detection failed"
    return
  fi

  # Apple Silicon + macOS 14+: use Private Wi-Fi Address cycling
  if [[ "$APPLE_SILICON_MODERN" = true && "$INTERFACE_KIND" == "wifi" ]]; then
    echo "[*] Apple Silicon + macOS 14+ detected — using Private Wi-Fi Address cycling"
    if [[ -n "$WIFI_SERVICE" ]]; then
      local current_mode
      current_mode="$(networksetup -getPrivateNetworkAddress "$WIFI_SERVICE" 2>/dev/null || echo "unsupported")"
      echo "[*] Current Private Address mode: $current_mode"

      # Cycle: set to rotating if off, or toggle off/on to force new address
      networksetup -setPrivateNetworkAddress "$WIFI_SERVICE" rotating 2>/dev/null || true

      echo "[*] Cycling Wi-Fi to apply new address..."
      networksetup -setairportpower "$WIFI_DEVICE" off 2>/dev/null || true
      sleep 1
      networksetup -setairportpower "$WIFI_DEVICE" on 2>/dev/null || true
      sleep 3

      local new_mac
      new_mac="$(ifconfig "$WIFI_DEVICE" 2>/dev/null | awk '/ether/{print $2}')"
      echo "[+] Wi-Fi MAC is now: ${new_mac:-unknown}"
    else
      echo "[!] Could not determine Wi-Fi network service name"
    fi
    return
  fi

  # Traditional MAC spoofing for Intel or Ethernet
  local current_mac new_mac
  current_mac="$(ifconfig "$ACTIVE_DEVICE" 2>/dev/null | awk '/ether/{print $2}')"
  echo "[*] Current MAC on $ACTIVE_DEVICE: ${current_mac:-unknown}"

  new_mac="$(random_mac)"
  echo "[*] Spoofing MAC to: $new_mac"

  if [[ "$INTERFACE_KIND" == "wifi" ]]; then
    networksetup -setairportpower "$WIFI_DEVICE" off 2>/dev/null || true
    sleep 1
  else
    ifconfig "$ACTIVE_DEVICE" down 2>/dev/null || true
    sleep 1
  fi

  # Try lladdr first (modern macOS), then ether
  if ifconfig "$ACTIVE_DEVICE" lladdr "$new_mac" 2>/dev/null \
     || ifconfig "$ACTIVE_DEVICE" ether "$new_mac" 2>/dev/null; then
    echo "[+] MAC spoofed on $ACTIVE_DEVICE"
  else
    echo "[!] MAC spoof failed on $ACTIVE_DEVICE"
  fi

  # Bring interface back up
  if [[ "$INTERFACE_KIND" == "wifi" ]]; then
    networksetup -setairportpower "$WIFI_DEVICE" on 2>/dev/null || ifconfig "$ACTIVE_DEVICE" up 2>/dev/null || true
    sleep 2
  else
    ifconfig "$ACTIVE_DEVICE" up 2>/dev/null || true
    sleep 1
  fi

  # Recycle the network service to force reconnection
  if [[ -n "$ACTIVE_SERVICE" ]]; then
    networksetup -setnetworkserviceenabled "$ACTIVE_SERVICE" off 2>/dev/null || true
    sleep 1
    networksetup -setnetworkserviceenabled "$ACTIVE_SERVICE" on 2>/dev/null || true
    sleep 2
  fi

  # Renew DHCP
  networksetup -setdhcp "$ACTIVE_DEVICE" 2>/dev/null || true
  ipconfig set "$ACTIVE_DEVICE" DHCP 2>/dev/null || true

  local verify_mac
  verify_mac="$(ifconfig "$ACTIVE_DEVICE" 2>/dev/null | awk '/ether/{print $2}')"
  echo "[*] Verified MAC: ${verify_mac:-unknown}"
}

spoof_mac

# ── Selective Zoom Data Wipe ────────────────────────────────────────────────
echo "[*] Acting on user: $TARGET_USER"

ZOOMDATA="${TARGET_HOME}/Library/Application Support/zoom.us/data"

if [ -d "$ZOOMDATA" ]; then
  echo "[*] Wiping encrypted databases and viper.ini..."
  shopt -s nullglob
  for match in "$ZOOMDATA"/*.enc.db "$ZOOMDATA"/*.enc.db-journal "$ZOOMDATA"/viper.ini; do
    if [ -f "$match" ]; then
      # Remove immutable flag if present
      if ls -lO "$match" 2>/dev/null | awk '{print $5}' | grep -qw "uchg"; then
        chflags nouchg "$match" 2>/dev/null || true
      fi
      rm -f "$match"
      echo "[+] Removed $(basename "$match")"
    fi
  done
  shopt -u nullglob
else
  echo "[!] Zoom data directory not found: $ZOOMDATA"
fi

# ── Full Cleanup: Caches, Preferences, Saved State, Logs ────────────────────
echo "[*] Clearing Zoom caches and preferences..."

rm -rf "${TARGET_HOME}/Library/Caches/us.zoom.xos" 2>/dev/null || true
rm -rf "${TARGET_HOME}/Library/WebKit/us.zoom.xos" 2>/dev/null || true
rm -rf "${TARGET_HOME}/Library/HTTPStorages/us.zoom.xos" 2>/dev/null || true
rm -rf "${TARGET_HOME}/Library/HTTPStorages/us.zoom.xos.binarycookies" 2>/dev/null || true
rm -rf "${TARGET_HOME}/Library/Saved Application State/us.zoom.xos.savedState" 2>/dev/null || true
rm -rf "${TARGET_HOME}/Library/Logs/zoom.us" 2>/dev/null || true
rm -f "${TARGET_HOME}/Library/Logs/zoomusinstall.log"* 2>/dev/null || true

# Delete preferences (this is critical — contains PresAppKeyHash identifiers)
if [ -f "${TARGET_HOME}/Library/Preferences/us.zoom.xos.plist" ]; then
  rm -f "${TARGET_HOME}/Library/Preferences/us.zoom.xos.plist"
  echo "[+] Removed us.zoom.xos.plist"
fi
defaults delete us.zoom.xos 2>/dev/null || true

echo "[+] Caches and preferences cleared"

# ── DNS Flush ───────────────────────────────────────────────────────────────
if [[ "$PARTIAL_MODE" = false ]]; then
  echo "[*] Flushing DNS cache..."
  dscacheutil -flushcache 2>/dev/null || true
  killall -HUP mDNSResponder 2>/dev/null || true
  echo "[+] DNS flushed"
fi

# ── Launch Zoom in Sandbox ──────────────────────────────────────────────────
ZOOM_BINARY="/Applications/zoom.us.app/Contents/MacOS/zoom.us"

launch_zoom() {
  if [ ! -x "$ZOOM_BINARY" ]; then
    echo "[!] Zoom binary not found at $ZOOM_BINARY — falling back to open"
    sudo -u "$CONSOLE_USER" open -a "zoom.us" 2>/dev/null || true
    return
  fi

  # Sandbox profile: deny Zoom access to hardware identifiers
  SANDBOX_PROFILE="$(mktemp /tmp/zoomrecovery-sandbox.XXXXXX)"
  cat > "$SANDBOX_PROFILE" << 'SBEOF'
(version 1)
(allow default)
(allow device-camera)
(allow device-microphone)
(deny iokit-get-properties
    (iokit-property "IOPlatformSerialNumber")
    (iokit-property "IOPlatformUUID")
    (iokit-property "board-id")
    (iokit-property "IOMACAddress")
)
(deny file-read-data
    (literal "/Library/Preferences/SystemConfiguration/NetworkInterfaces.plist")
)
SBEOF

  cleanup_sandbox() {
    rm -f "$SANDBOX_PROFILE" 2>/dev/null || true
  }
  trap cleanup_sandbox EXIT

  echo "[*] Launching Zoom in sandboxed mode (blocking hardware ID reads)..."

  # Bootstrap: run sandboxed briefly so Zoom regenerates identity data
  sudo -u "$CONSOLE_USER" sandbox-exec -f "$SANDBOX_PROFILE" "$ZOOM_BINARY" >/dev/null 2>&1 &
  local bootstrap_pid=$!
  sleep 1

  if ! kill -0 "$bootstrap_pid" 2>/dev/null; then
    echo "[!] Sandbox bootstrap failed — falling back to persistent sandbox"
    sudo -u "$CONSOLE_USER" sandbox-exec -f "$SANDBOX_PROFILE" "$ZOOM_BINARY" >/dev/null 2>&1 &
    sleep 2
    if pgrep -x "zoom.us" >/dev/null 2>&1; then
      echo "[+] Zoom launched (persistent sandbox)"
    else
      echo "[!] Sandbox launch failed — opening Zoom normally"
      sudo -u "$CONSOLE_USER" open -a "zoom.us" 2>/dev/null || true
    fi
    return
  fi

  # Let bootstrap run for ~11 seconds to regenerate identity
  local waited=0
  while [[ $waited -lt 11 ]]; do
    if ! kill -0 "$bootstrap_pid" 2>/dev/null; then
      break
    fi
    sleep 1
    waited=$((waited + 1))
  done

  # Kill the bootstrap and relaunch normally
  kill "$bootstrap_pid" 2>/dev/null || true
  sleep 1

  # Wait for bootstrap to fully exit
  for i in {1..5}; do
    kill -0 "$bootstrap_pid" 2>/dev/null || break
    sleep 1
  done

  sudo -u "$CONSOLE_USER" open -na "zoom.us" 2>/dev/null || true
  sleep 2

  if pgrep -x "zoom.us" >/dev/null 2>&1; then
    echo "[+] Zoom relaunched successfully"
  else
    echo "[!] Normal relaunch unstable — falling back to persistent sandbox"
    killall "zoom.us" 2>/dev/null || true
    sleep 1
    sudo -u "$CONSOLE_USER" sandbox-exec -f "$SANDBOX_PROFILE" "$ZOOM_BINARY" >/dev/null 2>&1 &
    sleep 2
    if pgrep -x "zoom.us" >/dev/null 2>&1; then
      echo "[+] Zoom launched (persistent sandbox)"
    else
      echo "[!] All launch methods failed — please open Zoom manually"
    fi
  fi
}

launch_zoom

echo "[+] Zoom Error 1132 recovery complete."
